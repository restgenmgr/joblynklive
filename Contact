<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JobLynk.live – Contact Us</title>
  <!-- Font Awesome 6 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background-color: #0B1C2C;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #EFF3F8;
      line-height: 1.6;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 30px;
    }

    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      border-bottom: 1px solid #1F374B;
      flex-wrap: wrap;
    }

    .logo img {
      height: 50px;
      width: auto;
      display: block;
    }

    .nav-links {
      display: flex;
      gap: 28px;
      align-items: center;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: #DBE5F0;
      text-decoration: none;
      font-weight: 500;
      font-size: 1rem;
      transition: 0.2s;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: #00FFC6;
    }

    /* Main contact card */
    .contact-card {
      background: #132435;
      border-radius: 28px;
      padding: 50px;
      margin: 60px 0;
      border: 1px solid #264A62;
      box-shadow: 0 15px 30px -10px #00000080;
    }

    h1 {
      font-size: 2.8rem;
      font-weight: 600;
      margin-bottom: 20px;
      color: #00FFC6;
    }

    .subhead {
      font-size: 1.3rem;
      color: #B8D1EC;
      margin-bottom: 40px;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      margin: 40px 0;
    }

    .contact-item {
      background: #0F2639;
      border-radius: 24px;
      padding: 30px;
      border: 1px solid #2A5777;
      transition: transform 0.2s;
    }

    .contact-item:hover {
      transform: translateY(-5px);
      border-color: #00FFC6;
    }

    .contact-item i {
      font-size: 2.5rem;
      color: #00FFC6;
      margin-bottom: 15px;
    }

    .contact-item h3 {
      font-size: 1.8rem;
      margin-bottom: 15px;
      color: #DBE5F0;
    }

    .contact-item p {
      margin: 10px 0;
      font-size: 1.1rem;
    }

    .contact-item a {
      color: #00FFC6;
      text-decoration: none;
    }

    .contact-item a:hover {
      text-decoration: underline;
    }

    .badge {
      display: inline-block;
      background: #1F3A4F;
      color: #00FFC6;
      border-radius: 60px;
      padding: 5px 15px;
      font-size: 0.9rem;
      margin-top: 10px;
    }

    .footer {
      border-top: 1px solid #1E3A4F;
      padding: 40px 0 30px;
      margin-top: 40px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 30px;
    }

    .footer-links a {
      color: #B0CFEC;
      text-decoration: none;
      margin-right: 30px;
    }

    .footer-copy {
      text-align: center;
      color: #6C93B0;
      font-size: 0.9rem;
      padding-bottom: 30px;
    }

    @media (max-width: 700px) {
      h1 { font-size: 2rem; }
      .contact-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Navbar -->
    <div class="navbar">
      <div class="logo">
        <img src="images/JobLynk.live.png" alt="JobLynk.live" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
        <span style="display:none; font-size: 1.8rem; font-weight: 700; color:#00FFC6;">JobLynk<span style="color:white;">.live</span></span>
      </div>
      <div class="nav-links">
        <a href="index.html">Home</a>
        <a href="pricing.html">Pricing</a>
        <a href="about.html">About</a>
        <a href="disclaimer.html">Disclaimer</a>
        <a href="contact.html" class="active">Contact</a>
        <a href="advertise.html">Advertise</a>
      </div>
    </div>

    <!-- Contact Content -->
    <div class="contact-card">
      <h1>Get in Touch</h1>
      <div class="subhead">We’re here to help – whether you have questions, partnership ideas, or need support.</div>

      <div class="contact-grid">
        <!-- Operations -->
        <div class="contact-item">
          <i class="fas fa-user-tie"></i>
          <h3>Operations</h3>
          <p><strong>Nigel Thomas</strong></p>
          <p><i class="fas fa-phone-alt" style="color:#00FFC6; width:25px;"></i> <a href="tel:+919769351231">+91 97693 51231</a></p>
          <p><i class="fas fa-envelope" style="color:#00FFC6; width:25px;"></i> <a href="mailto:nigelthomas@hotmail.com">nigelthomas@hotmail.com</a></p>
          <span class="badge">Partnerships, Strategy, General Inquiries</span>
        </div>

        <!-- Support & Data -->
        <div class="contact-item">
          <i class="fas fa-headset"></i>
          <h3>Support & Data</h3>
          <p><strong>Das</strong></p>
          <p><i class="fas fa-phone-alt" style="color:#00FFC6; width:25px;"></i> <a href="tel:+918369372112">+91 83693 72112</a></p>
          <p><i class="fas fa-envelope" style="color:#00FFC6; width:25px;"></i> <a href="mailto:joblynklive@gmail.com">joblynklive@gmail.com</a></p>
          <span class="badge">Technical Support, Data Reports, Account Help</span>
        </div>
      </div>

      <!-- Additional Info -->
      <div style="margin-top:40px; padding:20px; background:#0A1E30; border-radius:20px;">
        <p style="text-align:center; font-size:1.1rem;">
          <i class="fas fa-clock" style="color:#00FFC6; margin-right:10px;"></i>
          Response time: within 24 hours on business days.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer>
      <div class="footer">
        <div style="max-width:300px;">
          <img src="images/JobLynk.live.png" alt="JobLynk" style="height:40px;" onerror="this.style.display='none';">
          <p style="margin-top:15px;">Career Performance Platform — readiness, not listings.</p>
        </div>
        <div class="footer-links">
          <a href="about.html">About</a>
          <a href="pricing.html">Pricing</a>
          <a href="disclaimer.html">Disclaimer</a>
          <a href="contact.html">Contact</a>
          <a href="advertise.html">Advertise</a>
        </div>
      </div>
      <div class="footer-copy">
        © 2026 JobLynk.live – All rights reserved.
      </div>
    </footer>
  </div>
</body>
</html>
